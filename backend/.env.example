# ================================================================
# MECÂNI.CÃO PCM — Variáveis de Ambiente (Template)
# ================================================================
# Copie este arquivo como .env e preencha com seus valores.
# Comando: cp .env.example .env
# ================================================================

# ---------------------------------------------------------------
# Banco de dados MySQL
# ---------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=sua_senha_aqui
DB_NAME=mecanicao_pcm

# ---------------------------------------------------------------
# Ambiente de execução
# ---------------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------------
# JWT (JSON Web Token) — Autenticação
# ---------------------------------------------------------------
JWT_SECRET=troque_por_um_secret_seguro_e_longo
JWT_EXPIRES_IN=8h

# ---------------------------------------------------------------
# Servidor Express
# ---------------------------------------------------------------
PORT=3333

# ---------------------------------------------------------------
# CORS — Origem permitida (URL do front-end)
# ---------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000
